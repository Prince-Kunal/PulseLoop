datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  DONOR
  HOSPITAL
  BLOOD_BANK
}

model User {
  id               String             @id @default(cuid())
  email            String             @unique
  password         String
  role             Role
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  donorProfile     DonorProfile?
  hospitalProfile  HospitalProfile?
  bloodBankProfile BloodBankProfile?
  notifications    UserNotification[]
}

model DonorProfile {
  id                 String              @id @default(cuid())
  userId             String              @unique
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName           String
  dateOfBirth        DateTime
  phone              String
  latitude           Float
  longitude          Float
  city               String?
  state              String?
  bloodGroup         String
  bloodGroupVerified Boolean             @default(false)
  lastDonationDate   DateTime?
  totalDonations     Int                 @default(0)
  livesImpacted      Int                 @default(0)
  currentStreak      Int                 @default(0)
  longestStreak      Int                 @default(0)
  nextEligibleDate   DateTime?
  lastActiveAt       DateTime?           @default(now())
  donations          DonationHistory[]
  badges             Badge[]
  userRewards        UserReward[]
  notifications      Notification[]
  responses          EmergencyResponse[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model HospitalProfile {
  id            String         @id @default(cuid())
  userId        String         @unique
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  hospitalName  String
  latitude      Float
  longitude     Float
  city          String?
  state         String?
  requests      BloodRequest[]
  notifications Notification[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model BloodBankProfile {
  id               String            @id @default(cuid())
  userId           String            @unique
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  bloodBankName    String
  latitude         Float
  longitude        Float
  city             String?
  state            String?
  donations        DonationHistory[]
  inventory        Inventory[]
  drives           BloodDrive[]
  assignedRequests BloodRequest[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model DonationHistory {
  id           String            @id @default(cuid())
  donorId      String
  donor        DonorProfile      @relation(fields: [donorId], references: [id], onDelete: Cascade)
  bloodBankId  String?
  bloodBank    BloodBankProfile? @relation(fields: [bloodBankId], references: [id], onDelete: SetNull)
  donationDate DateTime          @default(now())
  bloodType    String
  units        Int               @default(1)
  status       String            @default("COMPLETED")
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

model Badge {
  id               String         @id @default(cuid())
  name             String         @unique
  description      String
  icon             String
  requirementType  String
  requirementValue Int
  donorProfiles    DonorProfile[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model Reward {
  id          String       @id @default(cuid())
  name        String
  description String
  pointsCost  Int
  code        String
  isAvailable Boolean      @default(true)
  userRewards UserReward[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model UserReward {
  id         String       @id @default(cuid())
  donorId    String
  donor      DonorProfile @relation(fields: [donorId], references: [id], onDelete: Cascade)
  rewardId   String
  reward     Reward       @relation(fields: [rewardId], references: [id], onDelete: Cascade)
  redeemedAt DateTime     @default(now())
  status     String       @default("REDEEMED")
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
}

model Inventory {
  id          String           @id @default(cuid())
  bloodBankId String
  bloodBank   BloodBankProfile @relation(fields: [bloodBankId], references: [id], onDelete: Cascade)
  bloodGroup  String
  units       Int              @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([bloodBankId, bloodGroup])
}

model BloodDrive {
  id          String           @id @default(cuid())
  title       String
  description String
  date        DateTime
  startTime   String
  endTime     String
  latitude    Float
  longitude   Float
  capacity    Int
  organizerId String
  organizer   BloodBankProfile @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model BloodRequest {
  id            String            @id @default(cuid())
  hospitalId    String
  hospital      HospitalProfile   @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  bloodGroup    String
  unitsRequired Int
  urgency       String            // "LOW", "MEDIUM", "HIGH", "CRITICAL"
  notes         String?
  patientAge    Int?
  status        String            @default("PENDING") // "PENDING", "ACCEPTED", "IN_PROGRESS", "FULFILLED", "REJECTED", "EXPIRED"
  bloodBankId   String?
  bloodBank     BloodBankProfile? @relation(fields: [bloodBankId], references: [id], onDelete: SetNull)
  timeline      RequestTimeline[]
  notifications Notification[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model Notification {
  id             String              @id @default(cuid())
  donorId        String
  donor          DonorProfile        @relation(fields: [donorId], references: [id], onDelete: Cascade)
  bloodRequestId String
  bloodRequest   BloodRequest        @relation(fields: [bloodRequestId], references: [id], onDelete: Cascade)
  hospitalId     String
  hospital       HospitalProfile     @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  title          String
  message        String
  status         String              @default("SENT") // "SENT", "RESPONDED"
  createdAt      DateTime            @default(now())
  responses      EmergencyResponse[]
}

model EmergencyResponse {
  id             String       @id @default(cuid())
  notificationId String
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  donorId        String
  donor          DonorProfile @relation(fields: [donorId], references: [id], onDelete: Cascade)
  response       String       // "AVAILABLE", "UNAVAILABLE"
  respondedAt    DateTime     @default(now())
}

model RequestTimeline {
  id             String       @id @default(cuid())
  bloodRequestId String
  bloodRequest   BloodRequest @relation(fields: [bloodRequestId], references: [id], onDelete: Cascade)
  event          String       // "HOSPITAL_CREATED_REQUEST", "BLOOD_BANK_ACCEPTED", etc.
  timestamp      DateTime     @default(now())
}

model UserNotification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // "EMERGENCY_ALERT", "REWARD_UNLOCK", "ELIGIBILITY_REMINDER", "DRIVE_ANNOUNCEMENT"
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model CommunityPost {
  id          String   @id @default(cuid())
  title       String
  description String
  imageUrl    String?
  authorName  String
  authorRole  String   // "BLOOD_BANK", "ADMIN"
  createdAt   DateTime @default(now())
}
